  "keyFeatures": [
    "Public visitor pages for animals, habitats, and zoo services",
    "Role-based back-office (Administrator, Veterinarian, Employee)",
    "Animal health tracking with veterinarian reports",
    "Feeding logs and nutrition management",
    "Habitat suggestions and review workflow",
    "Testimonials moderation system",
    "REST JSON API for animals, habitats, services, schedules, and testimonials",
    "Cloudinary image upload integration",
    "Session-based authentication with CSRF protection",
    "Docker and local deployment support with MariaDB/MySQL"
  ],
  "publicApiSurface": [
    "GET /api/animals — List all animals",
    "GET /api/animals/{id} — Get animal by ID",
    "GET /api/habitats — List all habitats",
    "GET /api/habitats/{id} — Get habitat by ID",
    "GET /api/services — List all services",
    "GET /api/schedules — Get zoo opening schedules",
    "GET /api/testimonials — Get validated testimonials",
    "POST /contact/pages/send — Submit contact form",
    "POST /auth/pages/login — Authenticate user",
    "POST /testimonials/gest/create — Submit a testimonial"
  ]
